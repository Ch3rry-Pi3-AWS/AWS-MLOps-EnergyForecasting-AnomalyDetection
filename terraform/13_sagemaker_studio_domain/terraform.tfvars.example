aws_region         = "eu-west-2"
deployment_name    = "energyops-dev-creative-antelope"
kms_key_arn        = "arn:aws:kms:eu-west-2:123456789012:key/replace-me"
sagemaker_role_arn = "arn:aws:iam::123456789012:role/iam-sagemaker-energyops-dev-creative-antelope"

# Optional explicit overrides if you do not want the module to fall back to the
# account's default VPC and its subnets.
# vpc_id = "vpc-0123456789abcdef0"
# subnet_ids = ["subnet-0123456789abcdef0", "subnet-abcdef01234567890"]

tags = {
  Environment = "dev"
  Project     = "Real-Time Energy Forecasting and Anomaly Detection"
}
